<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 AI Analyzer"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personalised Health Insights from Your AQI Data"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="24dp" />

        <!-- Analyze Button -->
        <Button
            android:id="@+id/btn_analyze"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⚡ Analyze Recent Air Trends"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/bg_btn_analyze"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp" />

        <!-- ═══ VISUAL REPORT (hidden until analysis runs) ═══ -->
        <LinearLayout
            android:id="@+id/report_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Category + Trend Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tv_category_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_category_badge"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Good"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_trend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="→ Stable"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#64748B" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_reading_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 readings"
                    android:textSize="12sp"
                    android:textColor="#94A3B8" />
            </LinearLayout>

            <!-- Stats Row: Min | Avg | Max -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Min Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MIN"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tv_stat_min"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#22C55E"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Avg Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tv_stat_avg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#3B82F6"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Max Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card"
                    android:padding="14dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAX"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tv_stat_max"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- AQI Level Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:elevation="1dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AQI SCALE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <!-- Color bar segments -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:orientation="horizontal">

                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#22C55E" />
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#EAB308" />
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#F97316" />
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#EF4444" />
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#A855F7" />
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:background="#7F1D1D" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="0" android:textSize="9sp"
                        android:textColor="#94A3B8" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="50" android:textSize="9sp"
                        android:textColor="#94A3B8" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="100" android:textSize="9sp"
                        android:textColor="#94A3B8" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="150" android:textSize="9sp"
                        android:textColor="#94A3B8" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="200" android:textSize="9sp"
                        android:textColor="#94A3B8" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="300+" android:textSize="9sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ═══ AI INSIGHT CARD ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_analyzer_card"
            android:padding="24dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_result_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI HEALTH INSIGHT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#94A3B8"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <ProgressBar
                android:id="@+id/progress_analyzer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="#8B5CF6" />

            <TextView
                android:id="@+id/tv_analysis_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Press the button above to fetch your AQI data from Firebase and generate a comprehensive health analysis."
                android:textSize="15sp"
                android:textColor="#334155"
                android:lineSpacingExtra="5dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
